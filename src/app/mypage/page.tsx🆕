'use client'

import { useState, useEffect, useCallback } from 'react'
import { useRouter } from 'next/navigation'

type Theme = 'dark' | 'light' | 'yellow'
type Tab = 'profile' | 'stats' | 'history' | 'worklog' | 'bookmark' | 'keys'

const THEMES = {
  dark:   { bg: '#050510', surface: 'rgba(255,255,255,0.04)', border: 'rgba(255,255,255,0.08)', text: '#f0f0ff', muted: '#44446a', s2: 'rgba(255,255,255,0.02)' },
  light:  { bg: '#f0f2ff', surface: 'rgba(255,255,255,0.9)',  border: 'rgba(0,0,0,0.08)',       text: '#1a1a2e', muted: '#9999bb', s2: 'rgba(255,255,255,0.7)' },
  yellow: { bg: '#0a0900', surface: 'rgba(255,215,0,0.06)',   border: 'rgba(255,215,0,0.15)',    text: '#fff8dc', muted: '#aa9900', s2: 'rgba(255,215,0,0.03)' },
}

const TABS: { key: Tab; icon: string; label: string; color: string }[] = [
  { key: 'profile',  icon: '👤', label: '프로필',   color: '#ff6b35' },
  { key: 'stats',    icon: '📊', label: '통계',     color: '#3b82f6' },
  { key: 'history',  icon: '📋', label: '히스토리', color: '#10b981' },
  { key: 'worklog',  icon: '📝', label: '작업일지', color: '#f59e0b' },
  { key: 'bookmark', icon: '⭐', label: '즐겨찾기', color: '#f59e0b' },
  { key: 'keys',     icon: '🔑', label: 'API 키',   color: '#8b5cf6' },
]

const BIZ = ['음식점/카페','소매업/편의점','온라인 쇼핑몰','제조업','서비스업','뷰티/미용','학원/교육','의류/패션','농업/축산','기타']
const REGS = ['서울','부산','인천','대구','광주','대전','울산','세종','경기','강원','충북','충남','전북','전남','경북','경남','제주']
const AC = '#ff6b35'
const SU = process.env.NEXT_PUBLIC_SUPABASE_URL || ''
const SK = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || ''

export default function MyPage() {
  const router = useRouter()
  const [theme, setTheme] = useState<Theme>('dark')
  const [tab, setTab] = useState<Tab>('profile')
  const [uid, setUid] = useState('')
  const [tok, setTok] = useState('')
  const [email, setEmail] = useState('')
  const [prof, setProf] = useState({ name:'', business_name:'', phone:'', business_type:'', region:'' })
  const [stats, setStats] = useState<{type:string;created_at:string}[]>([])
  const [bmarks, setBmarks] = useState<{id:string;title:string;url:string;category:string}[]>([])
  const [logs, setLogs] = useState<{id:string;title:string;content:string;category:string;created_at:string}[]>([])
  const [keys, setKeys] = useState({ gemini:'', openai:'', groq:'' })
  const [loading, setLoading] = useState(true)
  const [saving, setSaving] = useState(false)
  const [wS, setWS] = useState(false)
  const [wT, setWT] = useState('')
  const [wC, setWC] = useState('')
  const [wCat, setWCat] = useState('일반')
  const [toast, setToast] = useState('')

  const T = THEMES[theme]
  const pop = (msg: string) => { setToast(msg); setTimeout(() => setToast(''), 2500) }
  const stT = (t: Theme) => { setTheme(t); try { localStorage.setItem('storeauto_theme', t) } catch { /**/ } }

  const load = useCallback(async (id: string, token: string) => {
    const h = { apikey: SK, Authorization: `Bearer ${token}` }
    try {
      const [p, u, b, w] = await Promise.all([
        fetch(`${SU}/rest/v1/profiles?id=eq.${id}&select=*&limit=1`, { headers: h }).then(r => r.json()),
        fetch(`${SU}/rest/v1/usage_stats?user_id=eq.${id}&order=created_at.desc&limit=100`, { headers: h }).then(r => r.json()),
        fetch(`${SU}/rest/v1/bookmarks?user_id=eq.${id}&order=created_at.desc`, { headers: h }).then(r => r.json()),
        fetch(`${SU}/rest/v1/work_logs?user_id=eq.${id}&order=created_at.desc&limit=50`, { headers: h }).then(r => r.json()),
      ])
      if (Array.isArray(p) && p[0]) setProf({ name: p[0].name||''  , business_name: p[0].business_name||'', phone: p[0].phone||'', business_type: p[0].business_type||'', region: p[0].region||'' })
      if (Array.isArray(u)) setStats(u)
      if (Array.isArray(b)) setBmarks(b)
      if (Array.isArray(w)) setLogs(w)
    } catch { /**/ }
    setLoading(false)
  }, [])

  useEffect(() => {
    if (typeof window === 'undefined') return
    try { const t = localStorage.getItem('storeauto_theme') as Theme; if (t && THEMES[t]) setTheme(t) } catch { /**/ }
    try {
      const s = JSON.parse(localStorage.getItem('sa_session') || 'null')
      if (!s || !s.id) { router.replace('/login'); return }
      setUid(s.id); setTok(s.access_token); setEmail(s.email)
      const k = JSON.parse(localStorage.getItem(`storeauto_keys_${s.id}`) || '{}')
      setKeys({ gemini: k.gemini||'', openai: k.openai||'', groq: k.groq||'' })
      load(s.id, s.access_token)
    } catch { router.replace('/login') }
  }, [router, load])

  const saveProf = async () => {
    setSaving(true)
    try {
      await fetch(`${SU}/rest/v1/profiles`, { method: 'POST', headers: { 'Content-Type':'application/json', apikey: SK, Authorization:`Bearer ${tok}`, Prefer:'return=minimal,resolution=merge-duplicates' }, body: JSON.stringify({ id: uid, email, ...prof }) })
      pop('✅ 프로필 저장 완료!')
    } catch { pop('❌ 저장 실패') }
    setSaving(false)
  }

  const saveKeys = () => {
    try { localStorage.setItem(`storeauto_keys_${uid}`, JSON.stringify(keys)); localStorage.removeItem('storeauto_keys'); pop('✅ API 키 저장!') } catch { pop('❌ 실패') }
  }

  const logout = async () => {
    try { await fetch(`${SU}/auth/v1/logout`, { method:'POST', headers:{ apikey:SK, Authorization:`Bearer ${tok}` } }) } catch { /**/ }
    try { localStorage.removeItem('sa_session') } catch { /**/ }
    router.push('/login')
  }

  const addLog = async () => {
    if (!wT.trim()) return; setWS(true)
    try {
      const r = await fetch(`${SU}/rest/v1/work_logs`, { method:'POST', headers:{'Content-Type':'application/json',apikey:SK,Authorization:`Bearer ${tok}`,Prefer:'return=representation'}, body:JSON.stringify({user_id:uid,title:wT,content:wC,category:wCat}) })
      const d = await r.json(); if (Array.isArray(d) && d[0]) setLogs(p => [d[0],...p])
      setWT(''); setWC(''); pop('✅ 저장!')
    } catch { pop('❌ 실패') }
    setWS(false)
  }

  const delLog = async (id: string) => {
    try { await fetch(`${SU}/rest/v1/work_logs?id=eq.${id}`,{method:'DELETE',headers:{apikey:SK,Authorization:`Bearer ${tok}`}}); setLogs(p=>p.filter(w=>w.id!==id)) } catch {/**/ }
  }

  const delBmark = async (id: string) => {
    try { await fetch(`${SU}/rest/v1/bookmarks?id=eq.${id}`,{method:'DELETE',headers:{apikey:SK,Authorization:`Bearer ${tok}`}}); setBmarks(p=>p.filter(b=>b.id!==id)) } catch {/**/ }
  }

  const tM = stats.filter(s => new Date(s.created_at).getMonth()===new Date().getMonth()).length
  const bT = stats.reduce((a:{[k:string]:number},s) => { a[s.type]=(a[s.type]||0)+1; return a }, {})
  const TI: Record<string,{l:string;c:string;e:string}> = { detail_page:{l:'상세페이지',c:'#ff6b35',e:'📄'}, review:{l:'리뷰답글',c:'#10b981',e:'💬'}, government:{l:'정부지원',c:'#3b82f6',e:'🏛️'} }
  const iS: React.CSSProperties = { width:'100%', background:T.s2, border:`1px solid ${T.border}`, borderRadius:12, padding:'11px 14px', color:T.text, fontSize:14, outline:'none', fontFamily:"'Noto Sans KR',sans-serif", transition:'all 0.2s' }

  if (loading) return <div style={{minHeight:'100vh',background:T.bg,display:'flex',alignItems:'center',justifyContent:'center',fontFamily:"'Noto Sans KR',sans-serif",color:T.muted}}>불러오는 중...</div>

  return (
    <div style={{minHeight:'100vh',background:T.bg,color:T.text,fontFamily:"'Noto Sans KR',sans-serif"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap');
        @keyframes fIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        @keyframes tIn{from{opacity:0;transform:translateX(60px)}to{opacity:1;transform:translateX(0)}}
        *{box-sizing:border-box} input::placeholder,textarea::placeholder{color:${T.muted}}
        select option{background:#1a1a2e} ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-thumb{background:${T.border};border-radius:4px}
        @media(max-width:640px){.pcsb{display:none!important}#mtb{display:block!important}}
      `}</style>

      {toast && <div style={{position:'fixed',top:20,right:20,zIndex:9999,padding:'12px 20px',borderRadius:12,fontSize:14,fontWeight:700,background:toast.includes('✅')?'rgba(16,185,129,0.15)':'rgba(239,68,68,0.15)',border:`1px solid ${toast.includes('✅')?'rgba(16,185,129,0.3)':'rgba(239,68,68,0.3)'}`,color:toast.includes('✅')?'#34d399':'#f87171',animation:'tIn 0.3s ease',backdropFilter:'blur(20px)'}}>{toast}</div>}

      <div style={{background:T.surface,borderBottom:`1px solid ${T.border}`,padding:'0 16px',height:60,display:'flex',alignItems:'center',justifyContent:'space-between',position:'sticky',top:0,zIndex:100,backdropFilter:'blur(30px)'}}>
        <div style={{display:'flex',alignItems:'center',gap:10}}>
          <button onClick={()=>router.push('/')} style={{background:T.s2,border:`1px solid ${T.border}`,color:T.text,borderRadius:8,padding:'6px 12px',cursor:'pointer',fontSize:13,fontFamily:'inherit',fontWeight:700}}>← 홈</button>
          <span style={{fontSize:15,fontWeight:900}}>마이페이지</span>
        </div>
        <div style={{display:'flex',alignItems:'center',gap:8}}>
          {(['dark','light','yellow'] as Theme[]).map(t=>(
            <button key={t} onClick={()=>stT(t)} style={{width:28,height:28,borderRadius:'50%',border:`2px solid ${theme===t?AC:'transparent'}`,cursor:'pointer',fontSize:13,background:t==='dark'?'#1a1a2e':t==='light'?'#e8eaff':'#1a1600'}}>{t==='dark'?'🌙':t==='light'?'☀️':'⭐'}</button>
          ))}
          <button onClick={logout} style={{background:'rgba(239,68,68,0.1)',border:'1px solid rgba(239,68,68,0.2)',color:'#ef4444',borderRadius:8,padding:'6px 10px',cursor:'pointer',fontSize:12,fontFamily:'inherit'}}>로그아웃</button>
        </div>
      </div>

      <div style={{display:'flex',minHeight:'calc(100vh - 60px)'}}>
        <div className="pcsb" style={{width:190,flexShrink:0,background:T.surface,borderRight:`1px solid ${T.border}`,padding:'16px 8px',display:'flex',flexDirection:'column',gap:4}}>
          <div style={{background:T.s2,border:`1px solid ${T.border}`,borderRadius:12,padding:12,marginBottom:10,textAlign:'center'}}>
            <div style={{width:44,height:44,borderRadius:'50%',background:`linear-gradient(135deg,${AC},#ffd700)`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:20,margin:'0 auto 6px',fontWeight:900}}>{prof.name?prof.name[0]:'😊'}</div>
            <div style={{fontSize:13,fontWeight:800}}>{prof.name||'이름 없음'}</div>
            <div style={{fontSize:11,color:T.muted}}>{email}</div>
          </div>
          {TABS.map(t=>(
            <button key={t.key} onClick={()=>setTab(t.key)} style={{display:'flex',alignItems:'center',gap:8,padding:'10px 12px',borderRadius:10,cursor:'pointer',border:'none',fontFamily:'inherit',fontSize:13,fontWeight:800,textAlign:'left',width:'100%',transition:'all 0.2s',background:tab===t.key?`${t.color}18`:'transparent',color:tab===t.key?t.color:T.muted,borderLeft:tab===t.key?`3px solid ${t.color}`:'3px solid transparent'}}>
              <span style={{fontSize:16}}>{t.icon}</span>{t.label}
            </button>
          ))}
        </div>

        <div style={{flex:1,padding:'clamp(16px,3vw,28px)',overflowY:'auto',paddingBottom:80,animation:'fIn 0.3s ease'}}>

          {tab==='profile' && (
            <div style={{maxWidth:520}}>
              <SHd icon="👤" title="프로필 수정" color={AC}/>
              <div style={{display:'grid',gap:14}}>
                {([{l:'이름',k:'name',ph:'홍길동'},{l:'상호명',k:'business_name',ph:'OO마트'},{l:'연락처',k:'phone',ph:'010-0000-0000'}] as const).map(f=>(
                  <div key={f.k}>
                    <div style={{fontSize:12,color:T.muted,fontWeight:700,marginBottom:7}}>{f.l}</div>
                    <input value={prof[f.k]} onChange={e=>setProf(p=>({...p,[f.k]:e.target.value}))} placeholder={f.ph} style={iS}
                      onFocus={e=>{(e.target as HTMLInputElement).style.borderColor=AC}}
                      onBlur={e=>{(e.target as HTMLInputElement).style.borderColor=T.border}}
                    />
                  </div>
                ))}
                <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12}}>
                  <div>
                    <div style={{fontSize:12,color:T.muted,fontWeight:700,marginBottom:7}}>업종</div>
                    <select value={prof.business_type} onChange={e=>setProf(p=>({...p,business_type:e.target.value}))} style={{...iS,cursor:'pointer'}}>
                      <option value="">선택</option>
                      {BIZ.map(t=><option key={t} value={t}>{t}</option>)}
                    </select>
                  </div>
                  <div>
                    <div style={{fontSize:12,color:T.muted,fontWeight:700,marginBottom:7}}>지역</div>
                    <select value={prof.region} onChange={e=>setProf(p=>({...p,region:e.target.value}))} style={{...iS,cursor:'pointer'}}>
                      <option value="">선택</option>
                      {REGS.map(r=><option key={r} value={r}>{r}</option>)}
                    </select>
                  </div>
                </div>
                <GBt onClick={saveProf} loading={saving} label="💾 저장하기" color={`linear-gradient(135deg,${AC},#ffd700)`}/>
              </div>
            </div>
          )}

          {tab==='stats' && (
            <div>
              <SHd icon="📊" title="사용 통계" color="#3b82f6"/>
              <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(130px,1fr))',gap:12,marginBottom:20}}>
                {[{l:'이번달',v:tM,e:'🔥',c:AC},{l:'상세페이지',v:bT['detail_page']||0,e:'📄',c:'#8b5cf6'},{l:'리뷰답글',v:bT['review']||0,e:'💬',c:'#10b981'},{l:'정부지원',v:bT['government']||0,e:'🏛️',c:'#f59e0b'}].map((s,i)=>(
                  <div key={i} style={{background:`${s.c}10`,border:`1px solid ${s.c}25`,borderRadius:14,padding:16,textAlign:'center'}}>
                    <div style={{fontSize:24,marginBottom:4}}>{s.e}</div>
                    <div style={{fontSize:26,fontWeight:900,color:s.c}}>{s.v}</div>
                    <div style={{fontSize:11,color:T.muted,marginTop:2,fontWeight:700}}>{s.l}</div>
                  </div>
                ))}
              </div>
              {stats.length===0 && <Emp text="아직 사용 기록이 없어요"/>}
            </div>
          )}

          {tab==='history' && (
            <div>
              <SHd icon="📋" title="사용 히스토리" color="#10b981"/>
              {stats.length===0 ? <Emp text="아직 사용 기록이 없어요"/> : (
                <div style={{display:'flex',flexDirection:'column',gap:8}}>
                  {stats.slice(0,50).map((s,i)=>{const info=TI[s.type]||{l:s.type,c:AC,e:'📌'};return(
                    <div key={i} style={{background:T.surface,border:`1px solid ${T.border}`,borderRadius:12,padding:'12px 16px',display:'flex',alignItems:'center',gap:10}}>
                      <span style={{fontSize:18}}>{info.e}</span>
                      <div style={{flex:1}}><div style={{fontSize:13,fontWeight:700,color:info.c}}>{info.l}</div><div style={{fontSize:11,color:T.muted}}>{new Date(s.created_at).toLocaleString('ko-KR')}</div></div>
                    </div>
                  )})}
                </div>
              )}
            </div>
          )}

          {tab==='worklog' && (
            <div>
              <SHd icon="📝" title="작업일지" color="#f59e0b"/>
              <div style={{background:T.surface,border:`1px solid ${T.border}`,borderRadius:16,padding:18,marginBottom:18}}>
                <div style={{fontSize:13,fontWeight:800,color:'#f59e0b',marginBottom:12}}>+ 새 작업일지</div>
                <div style={{display:'flex',gap:8,marginBottom:10,flexWrap:'wrap'}}>
                  <select value={wCat} onChange={e=>setWCat(e.target.value)} style={{...iS,width:'auto',cursor:'pointer'}}>
                    {['일반','상품등록','마케팅','고객응대','정부지원','기타'].map(c=><option key={c} value={c}>{c}</option>)}
                  </select>
                  <input value={wT} onChange={e=>setWT(e.target.value)} placeholder="작업 제목" style={{...iS,flex:1,minWidth:120}}
                    onFocus={e=>{(e.target as HTMLInputElement).style.borderColor='#f59e0b'}}
                    onBlur={e=>{(e.target as HTMLInputElement).style.borderColor=T.border}}
                  />
                </div>
                <textarea value={wC} onChange={e=>setWC(e.target.value)} placeholder="작업 내용..." rows={3} style={{...iS,resize:'vertical',marginBottom:10}}/>
                <GBt onClick={addLog} loading={wS} label="📝 저장" color="linear-gradient(135deg,#f59e0b,#d97706)"/>
              </div>
              {logs.length===0 ? <Emp text="첫 작업일지를 작성해보세요!"/> : (
                <div style={{display:'flex',flexDirection:'column',gap:10}}>
                  {logs.map(w=>(
                    <div key={w.id} style={{background:T.surface,border:`1px solid ${T.border}`,borderRadius:14,padding:'14px 16px'}}>
                      <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:8}}>
                        <div style={{display:'flex',gap:6,alignItems:'center',flexWrap:'wrap'}}>
                          <span style={{fontSize:11,padding:'2px 8px',borderRadius:20,background:'rgba(245,158,11,0.15)',color:'#f59e0b',fontWeight:800}}>{w.category}</span>
                          <span style={{fontSize:14,fontWeight:900}}>{w.title}</span>
                        </div>
                        <button onClick={()=>delLog(w.id)} style={{background:'rgba(239,68,68,0.08)',border:'1px solid rgba(239,68,68,0.2)',color:'#ef4444',borderRadius:8,padding:'4px 8px',cursor:'pointer',fontSize:13}}>🗑</button>
                      </div>
                      {w.content && <div style={{fontSize:13,color:T.muted,lineHeight:1.7,whiteSpace:'pre-line'}}>{w.content}</div>}
                      <div style={{fontSize:11,color:T.muted,marginTop:6}}>{new Date(w.created_at).toLocaleString('ko-KR')}</div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          {tab==='bookmark' && (
            <div>
              <SHd icon="⭐" title="즐겨찾기" color="#f59e0b"/>
              {bmarks.length===0 ? <Emp text="저장된 즐겨찾기가 없어요"/> : (
                <div style={{display:'flex',flexDirection:'column',gap:8}}>
                  {bmarks.map(b=>(
                    <div key={b.id} style={{background:T.surface,border:`1px solid ${T.border}`,borderRadius:12,padding:'12px 16px',display:'flex',alignItems:'center',gap:10}}>
                      <span style={{fontSize:18}}>⭐</span>
                      <div style={{flex:1,minWidth:0}}><div style={{fontSize:13,fontWeight:700}}>{b.title}</div>{b.url&&<a href={b.url} target="_blank" rel="noopener noreferrer" style={{fontSize:11,color:'#60a5fa'}}>{b.url}</a>}</div>
                      <button onClick={()=>delBmark(b.id)} style={{background:'rgba(239,68,68,0.08)',border:'1px solid rgba(239,68,68,0.2)',color:'#ef4444',borderRadius:8,padding:'4px 8px',cursor:'pointer',fontSize:13}}>🗑</button>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          {tab==='keys' && (
            <div style={{maxWidth:480}}>
              <SHd icon="🔑" title="API 키 관리" color="#8b5cf6"/>
              <div style={{padding:'12px 14px',background:'rgba(139,92,246,0.06)',border:'1px solid rgba(139,92,246,0.15)',borderRadius:12,fontSize:13,color:'#a78bfa',lineHeight:1.7,marginBottom:18}}>
                🔒 API 키는 이 기기에만 저장됩니다.
              </div>
              {([{l:'Gemini API 키',k:'gemini',ph:'AIza...',bc:'#10b981'},{l:'OpenAI API 키',k:'openai',ph:'sk-...',bc:'#ef4444'},{l:'Groq API 키',k:'groq',ph:'gsk_...',bc:'#00e5a0'}] as const).map(f=>(
                <div key={f.k} style={{marginBottom:16}}>
                  <div style={{fontSize:12,color:T.muted,fontWeight:700,marginBottom:8}}>{f.l}</div>
                  <input type="password" value={keys[f.k]} onChange={e=>setKeys(k=>({...k,[f.k]:e.target.value}))} placeholder={f.ph} style={iS}
                    onFocus={e=>{(e.target as HTMLInputElement).style.borderColor='#8b5cf6'}}
                    onBlur={e=>{(e.target as HTMLInputElement).style.borderColor=T.border}}
                  />
                </div>
              ))}
              <GBt onClick={saveKeys} loading={false} label="💾 저장하기" color="linear-gradient(135deg,#8b5cf6,#6366f1)"/>
            </div>
          )}
        </div>
      </div>

      <div id="mtb" style={{display:'none',position:'fixed',bottom:0,left:0,right:0,zIndex:200,background:T.surface,borderTop:`1px solid ${T.border}`,paddingBottom:'env(safe-area-inset-bottom)',backdropFilter:'blur(30px)'}}>
        <div style={{display:'flex',justifyContent:'space-around',padding:'6px 0'}}>
          {TABS.map(t=>(
            <button key={t.key} onClick={()=>setTab(t.key)} style={{display:'flex',flexDirection:'column',alignItems:'center',gap:2,padding:'4px 0',flex:1,background:'transparent',border:'none',cursor:'pointer',color:tab===t.key?t.color:T.muted,fontFamily:'inherit',fontSize:9,fontWeight:800}}>
              <span style={{fontSize:18}}>{t.icon}</span>
              <span style={{whiteSpace:'nowrap'}}>{t.label}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  )
}

function SHd({icon,title,color}:{icon:string;title:string;color:string}){return(<div style={{display:'flex',alignItems:'center',gap:10,marginBottom:20}}><div style={{width:38,height:38,borderRadius:12,background:`${color}20`,display:'flex',alignItems:'center',justifyContent:'center',fontSize:18}}>{icon}</div><div style={{fontSize:18,fontWeight:900}}>{title}</div></div>)}
function GBt({onClick,loading,label,color}:{onClick:()=>void;loading:boolean;label:string;color:string}){return(<button onClick={onClick} disabled={loading} style={{padding:'11px 24px',borderRadius:12,border:'none',cursor:loading?'not-allowed':'pointer',fontFamily:"'Noto Sans KR',sans-serif",fontSize:14,fontWeight:800,color:'white',background:loading?'rgba(255,255,255,0.1)':color,opacity:loading?0.6:1,transition:'all 0.2s'}}>{loading?'저장 중...':label}</button>)}
function Emp({text}:{text:string}){return(<div style={{textAlign:'center',padding:'50px 20px',color:'#555'}}><div style={{fontSize:40,marginBottom:10,opacity:0.2}}>📭</div><div style={{fontSize:14}}>{text}</div></div>)}
